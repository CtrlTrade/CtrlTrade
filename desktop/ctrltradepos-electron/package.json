{
  "name": "@workspace/ctrltradepos-electron",
  "version": "1.0.11",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/CtrlTrade/CtrlTrade.git"
  },
  "main": "src/main.js",
  "scripts": {
    "build:web": "node scripts/check-env.mjs && dotenv -e .env --override=false -- pnpm --filter @workspace/ctrltradepos exec expo export --platform web --output-dir ../../desktop/ctrltradepos-electron/www",
    "build:main": "tsc -p tsconfig.json",
    "start": "pnpm run build:main && electron .",
    "dist:win": "pnpm run build:main && electron-builder --win --config electron-builder.config.js",
    "dist:mac": "pnpm run build:main && electron-builder --mac --config electron-builder.config.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "dotenv-cli": "^8.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.9.2"
  }
}
